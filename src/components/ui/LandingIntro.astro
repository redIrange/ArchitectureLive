---
/**
 * Header block for the sector / location landing pages: eyebrow, the page's
 * single <h1>, and a lead-prose slot. Matches the site's centred editorial
 * type scale.
 */
interface Props {
  eyebrow: string;
  headline: string;
}
const { eyebrow, headline } = Astro.props;
---
<div class="landing-intro">
  <p class="landing-eyebrow">{eyebrow}</p>
  <h1 class="landing-headline">{headline}</h1>
  <div class="landing-lead"><slot /></div>
</div>

<style>
.landing-intro {
  max-width: 60ch;
  margin: 0 auto;
  text-align: center;
}
.landing-eyebrow {
  margin: 0 0 var(--space-sm);
  font-family: var(--font-text);
  font-size: var(--type-eyebrow-size);
  font-weight: 600;
  letter-spacing: var(--type-eyebrow-tracking);
  text-transform: uppercase;
  color: var(--color-grey-light);
}
.landing-headline {
  margin: 0;
  font-family: var(--font-display);
  font-size: var(--type-hero-display-size);
  font-weight: 400;
  line-height: 1.05;
  letter-spacing: -0.5px;
  text-transform: uppercase;
  color: var(--color-charcoal);
}
.landing-lead {
  margin: var(--space-lg) auto 0;
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
  font-family: var(--font-text);
  font-size: var(--type-lead-airy-size);
  line-height: 1.6;
  color: var(--color-grey-mid);
}
.landing-lead :global(p) { margin: 0; }
.landing-lead :global(a) {
  color: var(--color-indigo-deep);
  text-decoration: underline;
  text-underline-offset: 2px;
}
.landing-lead :global(a:hover) { color: var(--color-indigo-vivid); }
@media (max-width: 600px) {
  .landing-headline { font-size: clamp(32px, 8vw, var(--type-hero-display-size)); }
}
</style>
