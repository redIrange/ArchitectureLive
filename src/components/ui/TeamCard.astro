---
/**
 * Team profile card — portrait, name, role, short bio.
 * Used on the About / Team page. Calm and editorial; no hover lift.
 */
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

interface Props {
  name: string;
  role?: string;
  bio?: string;
  image?: ImageMetadata;
}
const { name, role, bio, image } = Astro.props;
---
<div class="team-card">
  <div class="al-team-portrait">
    {image && (
      <Image
        src={image}
        alt={name}
        widths={[400, 800]}
        sizes="(max-width: 700px) 100vw, 25vw"
      />
    )}
  </div>
  <div class="al-team-info">
    <h3 class="al-team-name">{name}</h3>
    {role && <p class="al-team-role">{role}</p>}
  </div>
  {bio && <p class="al-team-bio">{bio}</p>}
</div>

<style>
.team-card {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.al-team-portrait {
  border-radius: var(--radius-md);
  overflow: hidden;
  aspect-ratio: 3 / 4;
}
.al-team-portrait img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.al-team-info {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.al-team-name {
  margin: 0;
  font-family: var(--font-display);
  font-size: var(--type-display-md-size);
  font-weight: 600;
  letter-spacing: -0.2px;
  color: var(--color-charcoal);
}

.al-team-role {
  margin: 0;
  font-family: var(--font-display);
  font-size: var(--type-eyebrow-size);
  font-weight: 600;
  letter-spacing: var(--type-eyebrow-tracking);
  text-transform: uppercase;
  color: var(--color-purple);
}

.al-team-bio {
  margin: 0;
  font-family: var(--font-text);
  font-size: var(--type-body-size);
  line-height: var(--type-body-leading);
  color: var(--color-grey-mid);
}
</style>
