---
import BaseHead from "../components/BaseHead.astro";
import type { ImageMetadata } from "astro";
// Self-hosted Quicksand (display face) — latin subset, the weights the design
// uses. Replaces the render-blocking Google Fonts @import; same-origin, swap.
import "@fontsource/quicksand/latin-300.css";
import "@fontsource/quicksand/latin-400.css";
import "@fontsource/quicksand/latin-500.css";
import "@fontsource/quicksand/latin-600.css";
import "@fontsource/quicksand/latin-700.css";
import "../styles/global.css";
interface Props {
  title: string;
  description?: string;
  ogImage?: ImageMetadata;
  type?: "website" | "article";
  publishedTime?: string;
  section?: string;
  noindex?: boolean;
  schemas?: unknown[];
}
const { title, description, ogImage, type, publishedTime, section, noindex, schemas } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={title}
      description={description}
      ogImage={ogImage}
      type={type}
      publishedTime={publishedTime}
      section={section}
      noindex={noindex}
      schemas={schemas}
    />
  </head>
  <body>
    <slot />
  </body>
</html>
