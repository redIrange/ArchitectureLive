---
import BaseHead from "../components/BaseHead.astro";
import type { ImageMetadata } from "astro";
import "../styles/global.css";
interface Props {
  title: string;
  description?: string;
  ogImage?: ImageMetadata;
  type?: "website" | "article";
  publishedTime?: string;
  section?: string;
  noindex?: boolean;
  schemas?: unknown[];
}
const { title, description, ogImage, type, publishedTime, section, noindex, schemas } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={title}
      description={description}
      ogImage={ogImage}
      type={type}
      publishedTime={publishedTime}
      section={section}
      noindex={noindex}
      schemas={schemas}
    />
  </head>
  <body>
    <slot />
  </body>
</html>
