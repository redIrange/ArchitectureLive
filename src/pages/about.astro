---
/**
 * About / Studio page — ArchitectureLIVE
 * Re-port of About.jsx (ui_kits/website/About.jsx) — design-refresh update.
 * Section order: hero → title (h1) → intro → team → story → process → belief.
 * Belief = lavender tint section (Section surface="tint"); not a dark ProjectTile.
 */
import { Picture } from "astro:assets";
import PageShell from "../layouts/PageShell.astro";
import Section from "../components/ui/Section.astro";
import Container from "../components/ui/Container.astro";
import TeamCard from "../components/ui/TeamCard.astro";
import { team } from "../lib/team";
import studioHero from "../content/projects/near-passivhaus-office-extension/hero-01.jpg";

const steps = [
  {
    n: "01",
    k: "Feasibility & brief",
    d: "We visit your property, appraise it, and help shape the brief. With our in-house cost consultant we set a realistic budget and test early options before going further.",
  },
  {
    n: "02",
    k: "Design & planning",
    d: "We develop the design through sketches and models, coordinate any specialist input, and manage the pre-application and planning process with the local authority.",
  },
  {
    n: "03",
    k: "Detail, tender & build",
    d: "We detail the building and interiors, secure Building Regulations approval, run the tender, and stay involved on site through to completion.",
  },
];
---

<PageShell
  title="Studio · ArchitectureLIVE"
  description="ArchitectureLIVE is a collaborative team of RIBA Chartered architects in Haslemere, Surrey, combining contemporary design with a hands-on, sustainable approach."
  active="about"
  ogImage={studioHero}
>

  {/* ── Hero: full-bleed studio image (94vh, slides under glass header) ──── */}
  {/* Default: AL office. Swap for a dedicated studio/team photo when available. */}
  <section class="hero" aria-label="The studio, Haslemere">
    <Picture
      src={studioHero}
      alt="ArchitectureLIVE studio, Fernhurst office extension"
      formats={["avif", "webp"]}
      widths={[800, 1200, 1920, 2560]}
      sizes="100vw"
      class="hero__image"
      loading="eager"
      fetchpriority="high"
    />
  </section>

  {/* ── Title — the page's single <h1> ──────────────────────────────────── */}
  <Section surface="light" pad="var(--space-xxl)">
    <div class="title-block">
      <p class="title-eyebrow">Haslemere, Surrey</p>
      <h1 class="title-headline">
        A studio for<br />contemporary,<br />sustainable<br />design
      </h1>
    </div>
  </Section>

  {/* ── Intro — centred lead prose ──────────────────────────────────────── */}
  <Section surface="light" pad="var(--space-section)" style="padding-top:0;">
    <div class="prose">
      <p>ArchitectureLIVE is a collaborative team of RIBA Chartered architects. Having built up our expertise with major architectural firms in London, we combine commercial know-how with a personal, hands-on approach. Based in Haslemere, our studio works across Surrey, West Sussex, Hampshire and beyond.</p>
    </div>
  </Section>

  {/* ── Team — moved high; before the story ─────────────────────────────── */}
  <Section surface="light" pad="var(--space-section)" style="padding-top:0;">
    <Container>
      <h2 class="team-headline">People you'll work with</h2>
      <div class="al-team">
        {team.map((member) => (
          <TeamCard
            name={member.name}
            role={member.role}
            bio={member.bio}
            image={member.image}
            email={member.email}
          />
        ))}
      </div>
    </Container>
  </Section>

  {/* ── Story — centred editorial prose (no split image) ────────────────── */}
  <Section surface="light" pad="var(--space-section)">
    <div class="prose prose--story">
      <p>Well considered architecture is fundamental to every aspect of life (living, learning and working) and enhances our wellbeing. We take our clients' lead on each project afresh and don't subscribe to a preconceived style. A holistic approach is central to how we work: we balance design, sustainability and technology so that none is delivered at the expense of the others.</p>
      <p>Using the principles of Passivhaus and BREEAM, we develop an approach for each project that helps our clients live responsibly for the foreseeable future. From the first conversation to the final handover, the people you meet are the people who design and deliver your project.</p>
      <p>Our work has been recognised at the Waverley Design Awards and featured on Channel 4's <em>Extraordinary Extensions</em>.</p>
    </div>
  </Section>

  {/* ── Process ─────────────────────────────────────────────────────────── */}
  <Section surface="alt" pad="var(--space-section)">
    <Container>
      <h2 class="process-headline">How we work</h2>
      <div class="al-grid-3">
        {steps.map((s) => (
          <div class="process-step">
            <div class="process-num">{s.n}</div>
            <h3 class="process-title">{s.k}</h3>
            <p class="process-desc">{s.d}</p>
          </div>
        ))}
      </div>
    </Container>
  </Section>

  {/* ── Belief — lavender tint text section (surface="tint") ────────────── */}
  <Section surface="tint" pad="var(--space-section)">
    <Container>
      <div class="belief">
        <span class="belief-eyebrow">In our words</span>
        <h2 class="belief-headline">Any element that contributes to a project, we make our business.</h2>
        <p class="belief-body">"Our design embraces every aspect of a project, from cost planning to the experience of inhabiting a space." Irene and Jonathan</p>
      </div>
    </Container>
  </Section>

</PageShell>

<style>
/* ── Hero ──────────────────────────────────────────────────────────────── */
.hero {
  margin-top: calc(-1 * var(--header-height));
  height: 94vh;
  overflow: hidden;
  background: var(--color-charcoal);
}
/* <Picture> wraps the <img> in a <picture>; make it fill the hero so the
   img's height:100% resolves against .hero (not the picture box). */
.hero :global(picture) {
  display: block;
  width: 100%;
  height: 100%;
}
.hero__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* ── Title block ────────────────────────────────────────────────────────── */
.title-block {
  text-align: center;
}

.title-eyebrow {
  margin: 0 0 var(--space-sm);
  font-family: var(--font-text);
  font-size: var(--type-eyebrow-size);
  font-weight: 600;
  letter-spacing: var(--type-eyebrow-tracking);
  text-transform: uppercase;
  color: var(--color-grey-light);
}

.title-headline {
  margin: 0;
  font-family: var(--font-display);
  font-size: var(--type-hero-display-size);
  font-weight: 400;
  line-height: 1.05;
  letter-spacing: -0.5px;
  text-transform: uppercase;
  color: var(--color-charcoal);
}

/* ── Prose (intro + story) ─────────────────────────────────────────────── */
.prose {
  max-width: 60ch;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
  font-family: var(--font-text);
  font-size: var(--type-lead-airy-size);
  line-height: 1.6;
  color: var(--color-charcoal);
  text-align: center;
}

.prose p {
  margin: 0;
}

.prose--story {
  max-width: 62ch;
}

/* ── Team ──────────────────────────────────────────────────────────────── */
.team-headline {
  margin: 0 0 var(--space-xxl);
  text-align: center;
  font-family: var(--font-display);
  font-size: var(--type-display-lg-size);
  font-weight: 400;
  letter-spacing: -0.3px;
  text-transform: uppercase;
  color: var(--color-charcoal);
}

.al-team {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-xl);
}

@media (max-width: 500px) {
  .al-team {
    grid-template-columns: 1fr;
  }
}

/* ── Process ───────────────────────────────────────────────────────────── */
.process-headline {
  margin: 0 0 var(--space-xxl);
  text-align: center;
  font-family: var(--font-display);
  font-size: var(--type-display-lg-size);
  font-weight: 400;
  letter-spacing: -0.3px;
  text-transform: uppercase;
  color: var(--color-charcoal);
}

.al-grid-3 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-xl);
}

@media (max-width: 900px) {
  .al-grid-3 {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 600px) {
  .al-grid-3 {
    grid-template-columns: 1fr;
  }
}

.process-step {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  text-align: center;
}

.process-num {
  font-family: var(--font-display);
  font-size: 44px;
  font-weight: 600;
  color: var(--color-lavender);
  letter-spacing: -1px;
}

.process-title {
  margin: 0;
  font-family: var(--font-display);
  font-size: var(--type-tagline-size);
  font-weight: 600;
  color: var(--color-charcoal);
}

.process-desc {
  margin: 0;
  font-family: var(--font-text);
  font-size: var(--type-body-size);
  line-height: 1.6;
  color: var(--color-grey-mid);
}

/* ── Belief ────────────────────────────────────────────────────────────── */
.belief {
  max-width: 30ch;
  margin: 0 auto;
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.belief-eyebrow {
  font-family: var(--font-display);
  font-size: var(--type-eyebrow-size);
  font-weight: 600;
  letter-spacing: var(--type-eyebrow-tracking);
  text-transform: uppercase;
  color: var(--color-indigo-deep);
}

.belief-headline {
  margin: 0;
  font-family: var(--font-display);
  font-size: var(--type-display-md-size);
  font-weight: 400;
  line-height: 1.3;
  letter-spacing: -0.2px;
  color: var(--color-indigo-deep);
}

.belief-body {
  margin: 0;
  font-family: var(--font-text);
  font-size: var(--type-lead-airy-size);
  line-height: 1.6;
  color: var(--color-indigo-slate);
}
</style>
