---
/**
 * About / Studio page — ArchitectureLIVE
 * Port of About.jsx (ui_kits/website/About.jsx).
 * Sections: Intro · Practice story · Process · Approach quote (dark tile) · Team grid.
 */
import PageShell from "../layouts/PageShell.astro";
import Section from "../components/ui/Section.astro";
import Container from "../components/ui/Container.astro";
import ProjectTile from "../components/ui/ProjectTile.astro";
import TeamCard from "../components/ui/TeamCard.astro";
import { team } from "../lib/team";

const steps = [
  {
    n: "01",
    k: "Concept",
    d: "We listen, visit the site, and explore ideas through sketches and models until the direction feels right.",
  },
  {
    n: "02",
    k: "Planning",
    d: "We develop the design and manage planning, conservation and building-regulations approvals on your behalf.",
  },
  {
    n: "03",
    k: "Completion",
    d: "We detail the building, support tendering, and stay involved on site through to handover.",
  },
];
---

<PageShell
  title="Studio — ArchitectureLIVE"
  description="A small, hands-on practice in Haslemere, Surrey — combining contemporary design with a genuine commitment to low-energy, sustainable living."
  active="about"
>

  {/* ── Intro ──────────────────────────────────────────────────── */}
  <Section surface="light" pad="var(--space-xxl)">
    <Container>
      <div class="intro-header">
        <div class="intro-eyebrow">About the studio</div>
        <h1 class="intro-headline">
          A studio for<br />contemporary,<br />sustainable<br />design
        </h1>
      </div>
      <p class="intro-lead">
        ArchitectureLIVE is a small, hands-on practice in Haslemere, Surrey. We work across the South of England on homes, schools and commercial spaces — combining contemporary design with a genuine commitment to low-energy, sustainable living.
      </p>
    </Container>
  </Section>

  {/* ── Practice story ────────────────────────────────────────── */}
  <Section surface="alt" pad="var(--space-section)">
    <Container>
      <div class="al-split">
        <div class="story-image-wrap">
          <div class="story-placeholder" aria-hidden="true">
            <span class="story-placeholder-label">The studio, Haslemere</span>
          </div>
        </div>
        <div class="story-text">
          <h2 class="story-headline">Craft, local knowledge, and a full service</h2>
          <p class="story-body">
            We know this landscape — Surrey, West Sussex, Hampshire and the South Downs National Park — and we know how to navigate planning and conservation here. From the first conversation to the final handover, the people you meet are the people who design and deliver your project.
          </p>
          <p class="story-body">
            Our work has been recognised at the Waverley Design Awards and featured on Channel 4's <em>Extraordinary Extensions</em>.
          </p>
        </div>
      </div>
    </Container>
  </Section>

  {/* ── Process ───────────────────────────────────────────────── */}
  <Section surface="light" pad="var(--space-section)">
    <Container>
      <h2 class="process-headline">How we work</h2>
      <div class="al-grid-3">
        {steps.map((s) => (
          <div class="process-step">
            <div class="process-num">{s.n}</div>
            <h3 class="process-title">{s.k}</h3>
            <p class="process-desc">{s.d}</p>
          </div>
        ))}
      </div>
    </Container>
  </Section>

  {/* ── Approach quote — dark tile ────────────────────────────── */}
  <ProjectTile
    surface="dark"
    media={false}
    align="center"
    eyebrow="Our belief"
    script="Sustainability and delight are the same project."
    sub="We design fabric-first buildings that are warm, quiet, inexpensive to run — and beautiful enough to be loved for generations."
  />

  {/* ── Team ──────────────────────────────────────────────────── */}
  <Section surface="alt" pad="var(--space-section)">
    <Container>
      <div class="team-eyebrow">The team</div>
      <h2 class="team-headline">People you'll work with</h2>
      <div class="al-team">
        {team.map((member) => (
          <TeamCard
            name={member.name}
            role={member.role}
            bio={member.bio}
            image={member.image}
          />
        ))}
      </div>
    </Container>
  </Section>

</PageShell>

<style>
/* ── Intro ──────────────────────────────────────────────────────── */
.intro-header {
  margin-bottom: var(--space-lg);
}

.intro-eyebrow {
  font-family: var(--font-display);
  font-size: var(--type-eyebrow-size);
  font-weight: 600;
  letter-spacing: var(--type-eyebrow-tracking);
  text-transform: uppercase;
  color: var(--color-purple);
  margin-bottom: 14px;
}

.intro-headline {
  margin: 0;
  font-family: var(--font-display);
  font-size: var(--type-hero-display-size);
  font-weight: 400;
  line-height: 1.05;
  letter-spacing: -0.5px;
  text-transform: uppercase;
  color: var(--color-charcoal);
}

.intro-lead {
  max-width: 58ch;
  font-family: var(--font-text);
  font-size: var(--type-lead-airy-size);
  line-height: 1.6;
  color: var(--color-grey-mid);
  margin: 0;
}

/* ── Story ──────────────────────────────────────────────────────── */
.al-split {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-xxl);
  align-items: center;
}

@media (max-width: 900px) {
  .al-split {
    grid-template-columns: 1fr;
  }
}

.story-image-wrap {
  filter: drop-shadow(var(--shadow-image));
}

.story-placeholder {
  aspect-ratio: 4 / 5;
  background: var(--color-lavender);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
}

.story-placeholder-label {
  font-family: var(--font-display);
  font-size: var(--type-caption-size);
  font-weight: 500;
  color: var(--color-indigo-deep);
  opacity: 0.7;
  text-align: center;
  padding: var(--space-md);
}

.story-text {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
  justify-content: center;
}

.story-headline {
  margin: 0;
  font-family: var(--font-display);
  font-size: var(--type-display-md-size);
  font-weight: 600;
  letter-spacing: -0.2px;
  color: var(--color-charcoal);
}

.story-body {
  margin: 0;
  font-family: var(--font-text);
  font-size: var(--type-body-size);
  line-height: 1.7;
  color: var(--color-grey-mid);
}

/* ── Process ────────────────────────────────────────────────────── */
.process-headline {
  margin: 0 0 var(--space-xxl);
  font-family: var(--font-display);
  font-size: var(--type-display-lg-size);
  font-weight: 600;
  letter-spacing: -0.3px;
  color: var(--color-charcoal);
}

.al-grid-3 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-xl);
}

@media (max-width: 900px) {
  .al-grid-3 {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 600px) {
  .al-grid-3 {
    grid-template-columns: 1fr;
  }
}

.process-step {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  padding-top: var(--space-md);
  border-top: 2px solid var(--color-lavender);
}

.process-num {
  font-family: var(--font-display);
  font-size: 44px;
  font-weight: 600;
  color: var(--color-lavender);
  letter-spacing: -1px;
}

.process-title {
  margin: 0;
  font-family: var(--font-display);
  font-size: var(--type-tagline-size);
  font-weight: 600;
  color: var(--color-charcoal);
}

.process-desc {
  margin: 0;
  font-family: var(--font-text);
  font-size: var(--type-body-size);
  line-height: 1.6;
  color: var(--color-grey-mid);
}

/* ── Team ───────────────────────────────────────────────────────── */
.team-eyebrow {
  font-family: var(--font-display);
  font-size: var(--type-eyebrow-size);
  font-weight: 600;
  letter-spacing: var(--type-eyebrow-tracking);
  text-transform: uppercase;
  color: var(--color-purple);
  margin-bottom: 12px;
}

.team-headline {
  margin: 0 0 var(--space-xxl);
  font-family: var(--font-display);
  font-size: var(--type-display-lg-size);
  font-weight: 600;
  letter-spacing: -0.3px;
  color: var(--color-charcoal);
}

.al-team {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-xl);
}

@media (max-width: 900px) {
  .al-team {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 500px) {
  .al-team {
    grid-template-columns: 1fr;
  }
}
</style>
