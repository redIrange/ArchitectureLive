---
/**
 * Contact page — ArchitectureLIVE
 * Port of Contact.jsx (ui_kits/website/Contact.jsx) — centred single column.
 * No form. Real details, live OpenStreetMap iframe, social links, hours/reply notes.
 * cta={false} — suppresses the CtaBand that links to /contact (this IS /contact).
 */
import PageShell from "../layouts/PageShell.astro";
import Section from "../components/ui/Section.astro";
import Container from "../components/ui/Container.astro";
import TextLink from "../components/ui/TextLink.astro";
---

<PageShell
  title="Contact · Architects in Haslemere, Surrey · ArchitectureLIVE"
  description="Get in touch with ArchitectureLIVE. Call, email, or visit our studio in Fernhurst, Haslemere, Surrey."
  active="contact"
  cta={false}
>

  {/* ── Title + intro ─────────────────────────────────────────── */}
  <Section surface="light" pad="var(--space-xxl)" style="padding-top:var(--space-section);">
    <Container>
      <div class="c-hero">
        <div class="c-eyebrow">Haslemere, Surrey</div>
        <h1 class="c-headline">Let's talk</h1>
        <p class="c-lead">
          Planning an extension, a new build or a project for your school or
          business? Give us a call or send an email. We'd love to hear about it.
        </p>
      </div>
    </Container>
  </Section>

  {/* ── Details + map ─────────────────────────────────────────── */}
  <Section surface="alt" pad="var(--space-section)" style="padding-top:var(--space-xl);">
    <Container>

      <div class="c-col">

        {/* Studio */}
        <div class="c-group">
          <div class="c-group-eyebrow">Studio</div>
          <address class="c-address">
            ArchitectureLIVE<br />
            Tall Trees, The Cylinders<br />
            Fernhurst, Haslemere<br />
            Surrey GU27 3EL
          </address>
          <p class="c-contact-line">
            <TextLink href="mailto:info@architecturelive.co.uk">
              info@architecturelive.co.uk
            </TextLink>
          </p>
          <p class="c-contact-line">
            <a href="tel:+441428652018" class="c-tel">+44 1428 652 018</a>
          </p>
        </div>

        {/* Social */}
        <div class="c-group">
          <div class="c-group-eyebrow">Find us online</div>
          <div class="c-social">
            <a href="https://www.houzz.co.uk/pro/architecturelive/architecturelive" class="c-social-link" rel="noopener noreferrer" target="_blank">Houzz</a>
            <a href="https://www.homify.co.uk/professionals/2952/architecturelive" class="c-social-link" rel="noopener noreferrer" target="_blank">Homify</a>
            <a href="https://www.linkedin.com/company/architecturelive" class="c-social-link" rel="noopener noreferrer" target="_blank">LinkedIn</a>
            <a href="https://www.instagram.com/architectureliveltd/" class="c-social-link" rel="noopener noreferrer" target="_blank">Instagram</a>
          </div>
        </div>

        {/* Working area */}
        <div class="c-group">
          <div class="c-group-eyebrow">Working across</div>
          <p class="c-coverage">
            Surrey &middot; West Sussex &middot; Hampshire &middot;
            Berkshire &middot; South Downs National Park
          </p>
        </div>

      </div>

      {/* Map — full-width below the detail column */}
      <div class="c-map-wrap">
        <iframe
          title="ArchitectureLIVE studio location, Fernhurst, Haslemere, Surrey"
          src="https://www.openstreetmap.org/export/embed.html?bbox=-0.7343%2C51.0420%2C-0.7143%2C51.0520&layer=mapnik&marker=51.04695%2C-0.72434"
          width="100%"
          height="360"
          loading="lazy"
          referrerpolicy="no-referrer"
          style="border:0;display:block;"
        ></iframe>
        <a
          href="https://www.openstreetmap.org/?mlat=51.04695&mlon=-0.72434#map=15/51.04695/-0.72434"
          class="c-map-credit"
          target="_blank"
          rel="noopener noreferrer"
        >
          View larger map
        </a>
      </div>

    </Container>
  </Section>

</PageShell>

<style>
/* ── Hero header ──────────────────────────────────────────────────── */
.c-hero {
  text-align: center;
}

.c-eyebrow {
  font-family: var(--font-text);
  font-size: var(--type-eyebrow-size);
  font-weight: 600;
  letter-spacing: var(--type-eyebrow-tracking);
  text-transform: uppercase;
  color: var(--color-grey-light);
  margin-bottom: var(--space-sm);
}

.c-headline {
  margin: 0;
  font-family: var(--font-display);
  font-size: var(--type-hero-display-size);
  font-weight: 400;
  line-height: 1.05;
  letter-spacing: -0.5px;
  text-transform: uppercase;
  color: var(--color-charcoal);
}

.c-lead {
  max-width: 52ch;
  margin: var(--space-lg) auto 0;
  font-family: var(--font-text);
  font-size: var(--type-lead-airy-size);
  line-height: 1.6;
  color: var(--color-grey-mid);
}

/* ── Centred detail column ────────────────────────────────────────── */
.c-col {
  max-width: 44ch;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: var(--space-xxl);
  text-align: center;
}

/* ── Group ────────────────────────────────────────────────────────── */
.c-group {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.c-group-eyebrow {
  font-family: var(--font-display);
  font-size: var(--type-eyebrow-size);
  font-weight: 600;
  letter-spacing: var(--type-eyebrow-tracking);
  text-transform: uppercase;
  color: var(--color-purple);
  margin-bottom: 2px;
}

.c-address {
  font-style: normal;
  font-family: var(--font-text);
  font-size: var(--type-lead-airy-size);
  line-height: 1.7;
  color: var(--color-charcoal);
  margin: 0;
}

.c-contact-line {
  margin: 0;
  font-family: var(--font-text);
  font-size: var(--type-lead-airy-size);
  line-height: 1.5;
}

.c-tel {
  font-weight: 500;
  color: var(--color-charcoal);
  text-decoration: none;
  transition: color var(--duration-base) var(--ease-standard);
}

.c-tel:hover {
  color: var(--color-indigo-deep);
}

.c-note {
  margin: 0;
  font-family: var(--font-text);
  font-size: var(--type-fine-print-size);
  color: var(--color-grey-light);
  line-height: 1.6;
}

/* ── Social links ────────────────────────────────────────────────── */
.c-social {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-lg);
  justify-content: center;
}

.c-social-link {
  font-family: var(--font-display);
  font-size: var(--type-caption-strong-size);
  font-weight: 600;
  color: var(--color-indigo-deep);
  text-decoration: none;
  transition: color var(--duration-base) var(--ease-standard);
}

.c-social-link:hover {
  color: var(--color-indigo-vivid);
}

/* ── Coverage ────────────────────────────────────────────────────── */
.c-coverage {
  margin: 0;
  font-family: var(--font-text);
  font-size: var(--type-body-size);
  line-height: 1.7;
  color: var(--color-grey-mid);
}

/* ── Map ─────────────────────────────────────────────────────────── */
.c-map-wrap {
  margin-top: var(--space-3xl);
  border-radius: var(--radius-md);
  overflow: hidden;
  border: var(--border-hairline);
  box-shadow: var(--shadow-card);
}

.c-map-credit {
  display: block;
  font-family: var(--font-text);
  font-size: var(--type-fine-print-size);
  color: var(--color-grey-light);
  padding: var(--space-xs) var(--space-sm);
  text-decoration: none;
  background: var(--color-white);
  text-align: right;
  transition: color var(--duration-base) var(--ease-standard);
}

.c-map-credit:hover {
  color: var(--color-indigo-deep);
}
</style>
