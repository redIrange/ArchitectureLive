---
/**
 * Home page — ArchitectureLIVE
 * Re-port of Home.jsx (ui_kits/website/Home.jsx) — design-refresh branch.
 * Sections: Hero (full-bleed, no overlay) · Intro h1 · Selected work (stacked) · Approach (text-only tint) · Latest news.
 * Removed: "What we do" sector cards, awards/press strip.
 * CtaBand is provided by PageShell (cta defaults to true) — not added here.
 */
import type { ImageMetadata } from "astro";
import { Image, Picture } from "astro:assets";
import { getCollection } from "astro:content";
import PageShell from "../layouts/PageShell.astro";
import Section from "../components/ui/Section.astro";
import Container from "../components/ui/Container.astro";
import SectionHead from "../components/ui/SectionHead.astro";
import NewsCard from "../components/ui/NewsCard.astro";
import Button from "../components/ui/Button.astro";

/* ── Hero slideshow images (src/assets/slider/*.jpg, sorted) ── */
const sliderMods = import.meta.glob<ImageMetadata>("../assets/slider/*.jpg", {
  eager: true,
  import: "default",
});
const sliderImages = Object.keys(sliderMods)
  .sort()
  .map((k) => sliderMods[k]);

/* ── Collection queries ── */
const projects = await getCollection("projects", (p) => !p.data.draft);
const latestNews = (await getCollection("news", (n) => !n.data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

/* ── Home "Selected work" — three chosen projects, in this order ── */
const HOME_PROJECT_SLUGS = [
  "country-house-lodsworth-west-sussex",    // Lodsworth
  "1960s-detached-house-haslemere-surrey",  // Courtsmount
  "1960s-bungalow-haslemere-surrey",        // Longdene
];
const homeProjects = HOME_PROJECT_SLUGS
  .map((slug) => projects.find((p) => p.id === slug))
  .filter((p): p is (typeof projects)[number] => Boolean(p));
---

<PageShell
  title="ArchitectureLIVE · Contemporary design & sustainable living"
  description="Contemporary design and sustainable living from a collaborative team of RIBA Chartered architects in Haslemere, Surrey, working across Surrey, West Sussex and Hampshire."
  active="home"
  ogImage={sliderImages[0]}
>

  {/* ── Hero — rotating cross-fade slideshow (src/assets/slider) ─ */}
  <section class="hero">
    {sliderImages.map((img, i) => (
      <Picture
        src={img}
        alt="Contemporary, sustainable architecture by ArchitectureLIVE"
        formats={["avif", "webp"]}
        widths={[800, 1200, 1920, 2560]}
        sizes="100vw"
        class={`hero__image${i === 0 ? " is-active" : ""}`}
        loading={i === 0 ? "eager" : "lazy"}
        fetchpriority={i === 0 ? "high" : undefined}
      />
    ))}
  </section>

  {/* ── Intro block — caption style; the page's single <h1> ──── */}
  <Section surface="light" pad="var(--space-section)">
    <div class="intro">
      <h1 class="intro__title">Contemporary design &amp; sustainable living</h1>
      <p class="intro__meta">A collaborative team of RIBA Chartered architects · Haslemere, Surrey</p>
    </div>
  </Section>

  {/* ── Selected work — full-bleed stacked images with captions ─ */}
  <section class="selected-work">
    {homeProjects.map((p, i) => (
      <div class="project-item">
        <a
          href={`/projects/${p.id}`}
          class={`project-band project-band--${i % 2 === 0 ? "wide" : "tall"}`}
          aria-label={p.data.title}
        >
          {p.data.heroImage && (
            <Image
              src={p.data.heroImage}
              alt={`${p.data.title}, ${p.data.location}`}
              widths={[800, 1200, 1920, 2560]}
              sizes="100vw"
              class="project-band__image"
            />
          )}
        </a>
        <div class="caption">
          <h2 class="caption__name">{p.data.location}</h2>
        </div>
      </div>
    ))}
    <div class="selected-work__cta">
      <Button href="/projects" variant="primary" size="large">View all projects</Button>
    </div>
  </section>

  {/* ── Approach — text-only on lavender, no image, no script line */}
  <Section surface="tint">
    <Container>
      <div class="approach">
        <span class="approach__eyebrow">Our approach</span>
        <h2 class="approach__headline">Design and sustainability, in balance</h2>
        <p class="approach__body">
          A holistic approach is central to our work: we balance design, sustainability and
          technology so that none is delivered at the expense of the others. Using the principles
          of Passivhaus and BREEAM, we shape a response for each project.
        </p>
        <div class="approach__cta">
          <Button href="/about" variant="primary">Read our story</Button>
        </div>
      </div>
    </Container>
  </Section>

  {/* ── Latest news ───────────────────────────────────────────── */}
  <Section surface="alt">
    <Container>
      <SectionHead
        eyebrow="From the journal"
        title="Latest news"
        link="All news"
        href="/news"
      />
      <div class="al-grid-3">
        {latestNews.map((n) => (
          <NewsCard
            href={`/news/${n.id}`}
            title={n.data.title}
            date={n.data.date}
            category={n.data.category}
            excerpt={n.data.excerpt}
            image={n.data.heroImage}
          />
        ))}
      </div>
    </Container>
  </Section>

</PageShell>

<script>
(function () {
  const imgs = /** @type {NodeListOf<HTMLElement>} */ (document.querySelectorAll('.hero__image'));
  if (imgs.length < 2) return;
  const mq = window.matchMedia('(prefers-reduced-motion: reduce)');
  if (mq.matches) return;
  let current = 0;
  setInterval(function () {
    imgs[current].classList.remove('is-active');
    current = (current + 1) % imgs.length;
    imgs[current].classList.add('is-active');
  }, 5000);
})();
</script>

<style>
/* ── Hero ─────────────────────────────────────────────────────── */
.hero {
  margin-top: calc(-1 * var(--header-height));
  height: 94vh;
  overflow: hidden;
  position: relative;
}
.hero__image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  opacity: 0;
  transition: opacity 800ms ease;
}
.hero__image.is-active {
  opacity: 1;
}

/* ── Intro block ──────────────────────────────────────────────── */
.intro {
  max-width: 40ch;
  margin: 0 auto;
  text-align: center;
}
.intro__title {
  margin: 0;
  font-family: var(--font-display);
  font-size: var(--type-display-md-size);
  font-weight: 300;
  line-height: 1.1;
  letter-spacing: -0.2px;
  text-transform: uppercase;
  color: var(--color-charcoal);
}
.intro__meta {
  margin: var(--space-md) 0 0;
  font-family: var(--font-text);
  font-size: var(--type-caption-size);
  letter-spacing: 0.4px;
  color: var(--color-grey-light);
}

/* ── Selected work ────────────────────────────────────────────── */
.project-item {
  /* stack: link then caption */
}
.project-band {
  display: block;
  overflow: hidden;
  cursor: pointer;
}
/* alternating aspect ratios: 16/9 and 3/2 */
.project-band--wide {
  aspect-ratio: 16 / 9;
}
.project-band--tall {
  aspect-ratio: 3 / 2;
}
.project-band__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.caption {
  text-align: center;
  padding: var(--space-xl) var(--space-xl) var(--space-xxl);
}
.caption__name {
  margin: 0;
  font-family: var(--font-display);
  font-size: var(--type-display-md-size);
  font-weight: 400;
  line-height: 1.1;
  letter-spacing: -0.2px;
  text-transform: uppercase;
  color: var(--color-charcoal);
}
.selected-work__cta {
  text-align: center;
  padding: var(--space-md) 0 var(--space-section);
}
.approach__cta {
  margin-top: var(--space-xs);
}

/* ── Approach (text-only, lavender) ───────────────────────────── */
.approach {
  max-width: 52ch;
  margin: 0 auto;
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}
.approach__eyebrow {
  font-family: var(--font-display);
  font-size: var(--type-eyebrow-size);
  font-weight: 600;
  letter-spacing: var(--type-eyebrow-tracking);
  text-transform: uppercase;
  color: var(--color-indigo-deep);
}
.approach__headline {
  margin: 0;
  font-family: var(--font-display);
  font-size: var(--type-display-lg-size);
  font-weight: 400;
  line-height: 1.12;
  letter-spacing: -0.3px;
  text-transform: uppercase;
  color: var(--color-indigo-deep);
}
.approach__body {
  margin: 0;
  font-family: var(--font-text);
  font-size: var(--type-lead-airy-size);
  line-height: 1.6;
  color: var(--color-indigo-slate);
}

/* ── News grid ────────────────────────────────────────────────── */
.al-grid-3 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-xl);
}
@media (max-width: 900px) {
  .al-grid-3 { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 600px) {
  .al-grid-3 { grid-template-columns: 1fr; }
}
</style>
