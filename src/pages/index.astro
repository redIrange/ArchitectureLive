---
/**
 * Home page — ArchitectureLIVE
 * Re-port of Home.jsx (ui_kits/website/Home.jsx) — design-refresh branch.
 * Sections: Hero (full-bleed, no overlay) · Intro h1 · Selected work (stacked) · Approach (text-only tint) · Latest news.
 * Removed: "What we do" sector cards, awards/press strip.
 * CtaBand is provided by PageShell (cta defaults to true) — not added here.
 */
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import PageShell from "../layouts/PageShell.astro";
import Section from "../components/ui/Section.astro";
import Container from "../components/ui/Container.astro";
import SectionHead from "../components/ui/SectionHead.astro";
import NewsCard from "../components/ui/NewsCard.astro";
import TextLink from "../components/ui/TextLink.astro";

/* ── Collection queries ── */
const projects = (await getCollection("projects", (p) => !p.data.draft))
  .sort((a, b) => (b.data.year ?? 0) - (a.data.year ?? 0));
const featured = projects.filter((p) => p.data.featured);
const featuredOrFallback = featured.length ? featured : projects.slice(0, 5);
const latestNews = (await getCollection("news", (n) => !n.data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

/* ── Slideshow: exactly 5 hero images, featured first then non-featured ── */
const slideshowProjects: typeof projects = [...featured.slice(0, 5)];
if (slideshowProjects.length < 5) {
  const usedIds = new Set(slideshowProjects.map((p) => p.id));
  const fillers = projects.filter((p) => !usedIds.has(p.id));
  slideshowProjects.push(...fillers.slice(0, 5 - slideshowProjects.length));
}
---

<PageShell
  title="ArchitectureLIVE — Contemporary architecture for sustainable living"
  description="A Surrey practice crafting low-energy homes, schools and spaces — from first sketch through planning to completion."
  active="home"
>

  {/* ── Hero — rotating cross-fade slideshow, 5 images ─────────── */}
  <section class="hero">
    {slideshowProjects.map((p, i) => p.data.heroImage && (
      <Image
        src={p.data.heroImage}
        alt={p.data.location ?? p.data.title}
        widths={[800, 1200, 1920, 2560]}
        sizes="100vw"
        class={`hero__image${i === 0 ? " is-active" : ""}`}
        loading={i === 0 ? "eager" : "lazy"}
        fetchpriority={i === 0 ? "high" : undefined}
      />
    ))}
  </section>

  {/* ── Intro block — the page's single <h1> ─────────────────── */}
  <Section surface="light" pad="var(--space-xxl)">
    <div class="intro">
      <p class="intro__eyebrow">ArchitectureLIVE — Haslemere, Surrey</p>
      <h1 class="intro__headline">Contemporary architecture for sustainable living</h1>
      <p class="intro__sub">A Surrey practice crafting low-energy homes, schools and spaces — from first sketch through planning to completion.</p>
    </div>
  </Section>

  {/* ── Selected work — full-bleed stacked images with captions ─ */}
  <section class="selected-work">
    <div class="selected-work__label-row">
      <p class="selected-work__eyebrow">Selected work</p>
    </div>
    {featuredOrFallback.slice(1).map((p, i) => (
      <div class="project-item">
        <a
          href={`/projects/${p.id}`}
          class={`project-band project-band--${i % 2 === 0 ? "wide" : "tall"}`}
          aria-label={p.data.title}
        >
          {p.data.heroImage && (
            <Image
              src={p.data.heroImage}
              alt={`${p.data.title} — ${p.data.location}`}
              widths={[800, 1200, 1920, 2560]}
              sizes="100vw"
              class="project-band__image"
            />
          )}
        </a>
        <div class="caption">
          <h2 class="caption__name">{p.data.location}</h2>
        </div>
      </div>
    ))}
    <div class="selected-work__cta">
      <TextLink href="/projects" arrow>View all projects</TextLink>
    </div>
  </section>

  {/* ── Approach — text-only on lavender, no image, no script line */}
  <Section surface="tint">
    <Container>
      <div class="approach">
        <span class="approach__eyebrow">Our approach</span>
        <h2 class="approach__headline">Low-energy living, beautifully made</h2>
        <p class="approach__body">
          We design fabric-first, Passivhaus-influenced buildings that are warm, quiet and
          inexpensive to run — and that sit gently in the Surrey, Sussex and Hampshire landscape.
        </p>
      </div>
    </Container>
  </Section>

  {/* ── Latest news ───────────────────────────────────────────── */}
  <Section surface="alt">
    <Container>
      <SectionHead
        eyebrow="From the journal"
        title="Latest news"
        link="All news"
        href="/news"
      />
      <div class="al-grid-3">
        {latestNews.map((n) => (
          <NewsCard
            href={`/news/${n.id}`}
            title={n.data.title}
            date={n.data.date}
            category={n.data.category}
            excerpt={n.data.excerpt}
            image={n.data.heroImage}
          />
        ))}
      </div>
    </Container>
  </Section>

</PageShell>

<script>
(function () {
  const imgs = /** @type {NodeListOf<HTMLElement>} */ (document.querySelectorAll('.hero__image'));
  if (imgs.length < 2) return;
  const mq = window.matchMedia('(prefers-reduced-motion: reduce)');
  if (mq.matches) return;
  let current = 0;
  setInterval(function () {
    imgs[current].classList.remove('is-active');
    current = (current + 1) % imgs.length;
    imgs[current].classList.add('is-active');
  }, 5000);
})();
</script>

<style>
/* ── Hero ─────────────────────────────────────────────────────── */
.hero {
  margin-top: calc(-1 * var(--header-height));
  height: 94vh;
  overflow: hidden;
  position: relative;
}
.hero__image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  opacity: 0;
  transition: opacity 800ms ease;
}
.hero__image.is-active {
  opacity: 1;
}

/* ── Intro block ──────────────────────────────────────────────── */
.intro {
  max-width: 34ch;
  margin: 0 auto;
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}
.intro__eyebrow {
  margin: 0;
  font-family: var(--font-display);
  font-size: var(--type-eyebrow-size);
  font-weight: 600;
  letter-spacing: var(--type-eyebrow-tracking);
  text-transform: uppercase;
  color: var(--color-grey-light);
}
.intro__headline {
  margin: 0;
  font-family: var(--font-display);
  font-size: var(--type-display-sm-size);
  font-weight: 400;
  line-height: 1.3;
  letter-spacing: -0.2px;
  color: var(--color-charcoal);
}
.intro__sub {
  margin: 0;
  font-family: var(--font-text);
  font-size: var(--type-body-size);
  line-height: 1.55;
  color: var(--color-grey-mid);
}

/* ── Selected work ────────────────────────────────────────────── */
.selected-work__label-row {
  text-align: center;
  padding: var(--space-xl) 0 var(--space-md);
}
.selected-work__eyebrow {
  margin: 0;
  font-family: var(--font-display);
  font-size: var(--type-eyebrow-size);
  font-weight: 600;
  letter-spacing: var(--type-eyebrow-tracking);
  text-transform: uppercase;
  color: var(--color-purple);
}

.project-item {
  /* stack: link then caption */
}
.project-band {
  display: block;
  overflow: hidden;
  cursor: pointer;
}
/* alternating aspect ratios: 16/9 and 3/2 */
.project-band--wide {
  aspect-ratio: 16 / 9;
}
.project-band--tall {
  aspect-ratio: 3 / 2;
}
.project-band__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.caption {
  text-align: center;
  padding: var(--space-xl) var(--space-xl) var(--space-xxl);
}
.caption__name {
  margin: 0;
  font-family: var(--font-display);
  font-size: var(--type-display-md-size);
  font-weight: 400;
  line-height: 1.1;
  letter-spacing: -0.2px;
  text-transform: uppercase;
  color: var(--color-charcoal);
}
.selected-work__cta {
  text-align: center;
  padding: var(--space-md) 0 var(--space-section);
  font-family: var(--font-text);
  font-size: var(--type-body-size);
}

/* ── Approach (text-only, lavender) ───────────────────────────── */
.approach {
  max-width: 52ch;
  margin: 0 auto;
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}
.approach__eyebrow {
  font-family: var(--font-display);
  font-size: var(--type-eyebrow-size);
  font-weight: 600;
  letter-spacing: var(--type-eyebrow-tracking);
  text-transform: uppercase;
  color: var(--color-indigo-deep);
}
.approach__headline {
  margin: 0;
  font-family: var(--font-display);
  font-size: var(--type-display-lg-size);
  font-weight: 400;
  line-height: 1.12;
  letter-spacing: -0.3px;
  text-transform: uppercase;
  color: var(--color-indigo-deep);
}
.approach__body {
  margin: 0;
  font-family: var(--font-text);
  font-size: var(--type-lead-airy-size);
  line-height: 1.6;
  color: var(--color-indigo-slate);
}

/* ── News grid ────────────────────────────────────────────────── */
.al-grid-3 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-xl);
}
@media (max-width: 900px) {
  .al-grid-3 { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 600px) {
  .al-grid-3 { grid-template-columns: 1fr; }
}
</style>
