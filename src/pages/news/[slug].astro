---
/**
 * News article page — ArchitectureLIVE
 * Re-ported to mirror the project detail page (projects/[slug].astro):
 * full-bleed hero → centred caption (category · date · read · lead) →
 * centred editorial prose → neat image band / gallery grid → share → related.
 *
 * News bodies are prose paragraphs followed by a stack of ./gNN.jpg images.
 * Those images are lifted out of the prose here so the article stays clean and
 * the photos can be arranged as a full-width band (single) or a responsive
 * gallery grid (multiple) — the same treatment the project pages use — instead
 * of a narrow left-aligned column at reading width.
 */
import type { ImageMetadata } from "astro";
import PageShell from "../../layouts/PageShell.astro";
import { Image, Picture, getImage } from "astro:assets";
import { getCollection } from "astro:content";
import { createMarkdownProcessor } from "@astrojs/markdown-remark";
import { splitBlocks } from "../../lib/project-body.mjs";
import { clampDescription, mentionsTown } from "../../lib/seo.mjs";
import Section from "../../components/ui/Section.astro";
import Container from "../../components/ui/Container.astro";
import NewsCard from "../../components/ui/NewsCard.astro";
import { readingTime } from "../../lib/reading-time.mjs";
import { articleSchema, breadcrumbSchema } from "../../lib/schema";

export async function getStaticPaths() {
  const posts = await getCollection("news", (n) => !n.data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const mins = readingTime(post.body);

const dateStr = post.data.date.toLocaleDateString("en-GB", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

/* ── Split body → centred prose + trailing images ─────────────────────
 * Every body image is a ./gNN.jpg living beside index.md; glob-import them
 * (a perfect 1:1 with the files on disk, so nothing extra is emitted) and
 * resolve each reference to its optimized ImageMetadata. */
const newsImages = import.meta.glob<ImageMetadata>(
  "../../content/news/**/g*.jpg",
  { eager: true, import: "default" },
);
const ZERO_WIDTH = /[​‌‍﻿]/g;
const IMG_ONLY = /^!\[[^\]]*\]\(([^)]+)\)$/;

const proseBlocks: string[] = [];
const bodyImages: ImageMetadata[] = [];
for (const raw of splitBlocks(post.body)) {
  const block = raw.replace(ZERO_WIDTH, "").trim();
  if (!block) continue;
  const match = block.match(IMG_ONLY);
  if (match) {
    const file = match[1].replace(/^\.\//, "");
    const img = newsImages[`../../content/news/${post.id}/${file}`];
    if (img) bodyImages.push(img);
  } else {
    proseBlocks.push(block);
  }
}

const mdProcessor = await createMarkdownProcessor({});
const proseHtml = proseBlocks.length
  ? (await mdProcessor.render(proseBlocks.join("\n\n"))).code
  : "";

// Related articles — same category first (topical), then newest overall, capped at 3
const otherPosts = (await getCollection("news", (n) => !n.data.draft && n.id !== post.id))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const relatedPosts = [
  ...otherPosts.filter((n) => n.data.category === post.data.category),
  ...otherPosts.filter((n) => n.data.category !== post.data.category),
].slice(0, 3);

// Related project — the portfolio entry whose town this post mentions (if any).
const relatedProject =
  (await getCollection("projects", (p) => !p.data.draft)).find((p) =>
    mentionsTown(`${post.data.title} ${post.data.excerpt}`, p.data.location),
  ) ?? null;

// Structured data — Article + breadcrumb (News → Category → Article).
const origin = new URL(Astro.site!).origin;
const canonical = `${origin}/news/${post.id}/`;
const heroOg = await getImage({ src: post.data.heroImage, width: 1200, format: "jpeg", quality: 80 });
const heroOgUrl = new URL(heroOg.src, Astro.site).href;
const schemas = [
  articleSchema({
    origin,
    url: canonical,
    headline: post.data.title,
    description: post.data.excerpt,
    image: heroOgUrl,
    datePublished: post.data.date.toISOString(),
    section: post.data.category,
  }),
  breadcrumbSchema([
    { name: "News", url: `${origin}/news/` },
    { name: post.data.category, url: `${origin}/news/category/${post.data.category.toLowerCase()}/` },
    { name: post.data.title, url: canonical },
  ]),
];
---

<PageShell
  title={`${post.data.title} · ArchitectureLIVE`}
  description={clampDescription(post.data.excerpt)}
  active="news"
  ogImage={post.data.heroImage}
  type="article"
  publishedTime={post.data.date.toISOString()}
  section={post.data.category}
  schemas={schemas}
>

  {/* ── Full-bleed hero (slides under the glass header) ─────────── */}
  <section class="article-hero" aria-label={post.data.title}>
    <Picture
      src={post.data.heroImage}
      alt={post.data.title}
      formats={["avif", "webp"]}
      widths={[800, 1200, 1920, 2560]}
      sizes="100vw"
      class="article-hero__image"
      loading="eager"
      fetchpriority="high"
    />
  </section>

  {/* ── Caption below hero — h1 lives here ──────────────────────── */}
  <Section surface="light" pad="var(--space-xxl)">
    <div class="article-caption">
      <div class="article-caption-eyebrow">{post.data.category}</div>
      <h1 class="article-caption-title">{post.data.title}</h1>
      <div class="article-caption-meta">
        By <a href="/about/" class="article-caption-author">ArchitectureLIVE</a> · {dateStr} · {mins} min read
      </div>
      {post.data.excerpt && (
        <p class="article-caption-lead">{post.data.excerpt}</p>
      )}
    </div>
  </Section>

  {/* ── Centred editorial prose ─────────────────────────────────── */}
  {proseHtml && (
    <Section surface="light" pad="var(--space-xl)">
      <div class="article-prose-wrap" set:html={proseHtml} />
    </Section>
  )}

  {/* ── Body images — single band / responsive gallery grid ─────── */}
  {bodyImages.length === 1 && (
    <div class="article-band">
      <Picture
        src={bodyImages[0]}
        formats={["avif", "webp"]}
        widths={[800, 1200, 1920, 2560]}
        sizes="100vw"
        alt={post.data.title}
        class="article-band-img"
      />
    </div>
  )}
  {bodyImages.length > 1 && (
    <div class="article-gallery-grid">
      {bodyImages.map((img, i) => (
        <Picture
          src={img}
          formats={["avif", "webp"]}
          widths={[400, 700, 1000]}
          sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
          alt={`${post.data.title}, view ${i + 1}`}
          class="article-gallery-grid-img"
        />
      ))}
    </div>
  )}

  {/* ── Related project — the portfolio entry this post documents ─ */}
  {relatedProject && (
    <Section surface="light" pad="var(--space-xl)">
      <div class="article-measure">
        <p class="article-related-project">
          See the project:{" "}
          <a href={`/projects/${relatedProject.id}/`}>{relatedProject.data.title}</a>
        </p>
      </div>
    </Section>
  )}

  {/* ── Share bar ───────────────────────────────────────────────── */}
  <Section surface="light" pad="var(--space-section)" style="padding-top:var(--space-xxl);">
    <div class="article-measure">
      <div class="article-share">
        <span class="article-share-label">Share</span>
        <a
          href={`https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(`https://architecturelive.co.uk/news/${post.id}`)}&title=${encodeURIComponent(post.data.title)}`}
          rel="noopener noreferrer"
          target="_blank"
          class="article-share-link"
        >LinkedIn</a>
        <button
          class="article-share-link article-copy-btn"
          aria-label="Copy article link"
        >Copy link</button>
      </div>
    </div>
  </Section>

  {/* ── Related reading ────────────────────────────────────────── */}
  {relatedPosts.length > 0 && (
    <Section surface="alt" pad="var(--space-section)">
      <Container>
        <h2 class="article-related-heading">Related reading</h2>
        <div class="article-related-grid">
          {relatedPosts.map((n) => (
            <NewsCard
              href={`/news/${n.id}/`}
              title={n.data.title}
              date={n.data.date}
              category={n.data.category}
              excerpt={n.data.excerpt}
              image={n.data.heroImage}
            />
          ))}
        </div>
      </Container>
    </Section>
  )}

</PageShell>

<style>
/* ── Full-bleed hero ─────────────────────────────────────────── */
.article-hero {
  margin-top: calc(-1 * var(--header-height));
  height: 94vh;
  overflow: hidden;
  background: var(--color-charcoal);
}
.article-hero__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
/* On mobile a 94vh hero crops the landscape photo's sides; show it full
   width at 16/9 (like the gallery bands) below the header instead. */
@media (max-width: 768px) {
  .article-hero {
    margin-top: 0;
    height: auto;
    aspect-ratio: 16 / 9;
  }
}

/* ── Caption block below hero ────────────────────────────────── */
.article-caption {
  text-align: center;
  max-width: 60ch;
  margin: 0 auto;
}
.article-caption-eyebrow {
  font-family: var(--font-text);
  font-size: var(--type-eyebrow-size);
  font-weight: 600;
  letter-spacing: var(--type-eyebrow-tracking);
  text-transform: uppercase;
  color: var(--color-grey-light);
  margin-bottom: var(--space-sm);
}
.article-caption-title {
  margin: 0;
  font-family: var(--font-display);
  font-size: var(--type-hero-display-size);
  font-weight: 400;
  line-height: 1.05;
  letter-spacing: -0.5px;
  text-transform: uppercase;
  color: var(--color-charcoal);
}
.article-caption-meta {
  margin-top: var(--space-md);
  font-family: var(--font-text);
  font-size: var(--type-caption-size);
  color: var(--color-grey-light);
}
.article-caption-author {
  color: var(--color-indigo-deep);
  text-decoration: none;
  font-weight: 600;
}
.article-caption-author:hover {
  color: var(--color-indigo-vivid);
  text-decoration: underline;
}
.article-related-project {
  margin: 0;
  font-family: var(--font-text);
  font-size: var(--type-body-size);
  color: var(--color-grey-mid);
}
.article-related-project a {
  color: var(--color-indigo-deep);
  font-weight: 600;
  text-decoration: underline;
  text-underline-offset: 2px;
}
.article-related-project a:hover {
  color: var(--color-indigo-vivid);
}
.article-caption-lead {
  max-width: 52ch;
  margin: var(--space-lg) auto 0;
  font-family: var(--font-text);
  font-size: var(--type-lead-airy-size);
  line-height: 1.6;
  color: var(--color-grey-mid);
}

/* ── Centred editorial prose (mirrors the project detail page) ──
 * :global() throughout — <set:html> Markdown renders beyond Astro's
 * scoped-style boundary, so scoped selectors would never match it. */
.article-prose-wrap {
  max-width: 60ch;
  margin: 0 auto;
  font-family: var(--font-text);
  font-size: var(--type-lead-airy-size);
  line-height: var(--type-lead-airy-leading);
  color: var(--color-charcoal);
  text-align: center;
}
.article-prose-wrap :global(h2) {
  font-family: var(--font-display);
  font-size: var(--type-display-md-size);
  font-weight: 600;
  letter-spacing: -0.2px;
  line-height: 1.2;
  color: var(--color-charcoal);
  margin: var(--space-xl) 0 var(--space-md);
}
.article-prose-wrap :global(h3) {
  font-family: var(--font-display);
  font-size: var(--type-tagline-size);
  font-weight: 600;
  letter-spacing: -0.1px;
  color: var(--color-charcoal);
  margin: var(--space-lg) 0 var(--space-sm);
}
.article-prose-wrap :global(h4) {
  font-family: var(--font-display);
  font-size: var(--type-tagline-size);
  font-weight: 600;
  line-height: 1.3;
  color: var(--color-charcoal);
  margin: var(--space-md) 0 var(--space-sm);
}
.article-prose-wrap :global(p) { margin: 0 0 var(--space-md); }
.article-prose-wrap :global(p:last-child) { margin-bottom: 0; }
.article-prose-wrap :global(ul),
.article-prose-wrap :global(ol) {
  margin: 0 0 var(--space-md);
  padding-left: 1.5em;
  text-align: left;
}
.article-prose-wrap :global(li) { margin-bottom: 0.4em; }
.article-prose-wrap :global(a) {
  color: var(--color-indigo-vivid);
  text-decoration: underline;
  text-underline-offset: 2px;
}
.article-prose-wrap :global(a:hover) { color: var(--color-indigo-deep); }
.article-prose-wrap :global(strong) {
  font-weight: 600;
  color: var(--color-charcoal);
}
.article-prose-wrap :global(em) { font-style: italic; }
.article-prose-wrap :global(blockquote) {
  margin: var(--space-lg) 0;
  border-left: 3px solid var(--color-purple);
  padding-left: var(--space-lg);
  text-align: left;
}
.article-prose-wrap :global(blockquote p) {
  font-family: var(--font-display);
  font-size: var(--type-display-md-size);
  font-weight: 500;
  line-height: 1.3;
  letter-spacing: -0.2px;
  color: var(--color-indigo-deep);
  margin: 0;
}
.article-prose-wrap :global(hr) {
  border: none;
  border-top: 1px solid var(--color-hairline);
  margin: var(--space-xl) 0;
}
.article-prose-wrap :global(img) {
  max-width: 100%;
  height: auto;
  display: block;
  margin: var(--space-lg) auto;
  border-radius: var(--radius-md);
}

/* ── Full-width image band ───────────────────────────────────── */
.article-band {
  width: 100%;
  line-height: 0;
}
.article-band-img {
  width: 100%;
  height: auto;
  aspect-ratio: 16 / 9;
  object-fit: cover;
  display: block;
}

/* ── Gallery grid (2+ images) ────────────────────────────────── */
.article-gallery-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 4px;
}
@media (min-width: 641px) {
  .article-gallery-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (min-width: 1025px) {
  .article-gallery-grid { grid-template-columns: repeat(3, 1fr); }
}
.article-gallery-grid-img {
  width: 100%;
  height: auto;
  aspect-ratio: 4 / 3;
  object-fit: cover;
  display: block;
}

/* ── Reading measure (share bar) ─────────────────────────────── */
.article-measure {
  max-width: var(--content-max-text);
  margin: 0 auto;
  padding: 0 var(--space-xl);
}

/* ── Share bar ──────────────────────────────────────────────── */
.article-share {
  display: flex;
  gap: var(--space-md);
  align-items: center;
  justify-content: center;
  padding-top: var(--space-lg);
  border-top: var(--border-hairline);
}
.article-share-label {
  font-family: var(--font-display);
  font-size: var(--type-eyebrow-size);
  font-weight: 600;
  letter-spacing: var(--type-eyebrow-tracking);
  text-transform: uppercase;
  color: var(--color-grey-light);
}
.article-share-link {
  font-family: var(--font-text);
  font-size: var(--type-caption-size);
  font-weight: 600;
  color: var(--color-indigo-deep);
  text-decoration: none;
  background: none;
  border: none;
  padding: 0;
  cursor: pointer;
}
.article-share-link:hover {
  color: var(--color-indigo-vivid);
  text-decoration: underline;
}

/* ── Related reading ────────────────────────────────────────── */
.article-related-heading {
  margin: 0 0 var(--space-xxl);
  font-family: var(--font-display);
  font-size: var(--type-display-md-size);
  font-weight: 600;
  color: var(--color-charcoal);
}
.article-related-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-xl);
}
@media (max-width: 900px) {
  .article-related-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 600px) {
  .article-caption-title { font-size: clamp(32px, 8vw, var(--type-hero-display-size)); }
  .article-related-grid { grid-template-columns: 1fr; }
}
</style>

<script>
// Copy link button — progressive enhancement
document
  .querySelector<HTMLButtonElement>(".article-copy-btn")
  ?.addEventListener("click", async () => {
    try {
      await navigator.clipboard.writeText(window.location.href);
    } catch {
      // fallback: no-op on failure
    }
  });
</script>
