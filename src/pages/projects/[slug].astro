---
/**
 * Project detail page — ArchitectureLIVE
 * Port of ProjectDetail.jsx (ui_kits/website/ProjectDetail.jsx).
 * Sections: breadcrumb · hero · caption · facts · body+gallery bands · testimonial · prev/next.
 * Lightbox omitted — static site.
 */
import PageShell from "../../layouts/PageShell.astro";
import { Image, Picture } from "astro:assets";
import { getCollection } from "astro:content";
import { createMarkdownProcessor } from "@astrojs/markdown-remark";
import { adjacent } from "../../lib/adjacent.mjs";
import { bodySegments } from "../../lib/project-body.mjs";
import { breadcrumbSchema } from "../../lib/schema";
import Section from "../../components/ui/Section.astro";
import Container from "../../components/ui/Container.astro";
import Testimonial from "../../components/ui/Testimonial.astro";
import Button from "../../components/ui/Button.astro";

export async function getStaticPaths() {
  const projects = (await getCollection("projects", (p) => !p.data.draft))
    .sort((a, b) => (b.data.year ?? 0) - (a.data.year ?? 0));
  const ids = projects.map((p) => p.id);
  const titleMap = Object.fromEntries(projects.map((p) => [p.id, p.data.title]));
  return projects.map((project) => {
    const { prev, next } = adjacent(ids, project.id);
    const prevTitle = prev ? titleMap[prev] : null;
    const nextTitle = next ? titleMap[next] : null;
    return { params: { slug: project.id }, props: { project, prev, next, prevTitle, nextTitle } };
  });
}

const { project, prev, next, prevTitle, nextTitle } = Astro.props;

// Render the body unchanged (same Markdown pipeline → same styling), but split
// into ordered segments so full-width gallery image bands can sit BETWEEN the
// prose paragraphs. Nothing is reordered or removed.
const mdProcessor = await createMarkdownProcessor({});
const proseHtml = await Promise.all(
  bodySegments(project.body).map(async (s) => (await mdProcessor.render(s)).code),
);
const gallery = [...project.data.gallery];
let gi = 0;
const bodyItems: Array<
  { type: "prose"; html: string } | { type: "image"; img: (typeof gallery)[number] }
> = [];
proseHtml.forEach((html, idx) => {
  bodyItems.push({ type: "prose", html });
  if (idx < proseHtml.length - 1 && gi < gallery.length) {
    bodyItems.push({ type: "image", img: gallery[gi++] });
  }
});
const leftover = gallery.slice(gi);

// Structured data — breadcrumb (Projects → Title). OG card uses the hero.
const origin = new URL(Astro.site!).origin;
const schemas = [
  breadcrumbSchema([
    { name: "Projects", url: `${origin}/projects/` },
    { name: project.data.title, url: `${origin}/projects/${project.id}/` },
  ]),
];
const heroAlt = `${project.data.title}, ${project.data.location}`;
---

<PageShell
  title={`${project.data.title} · ArchitectureLIVE`}
  description={project.data.excerpt || `${project.data.sector} project in ${project.data.location} by ArchitectureLIVE.`}
  active="projects"
  ogImage={project.data.heroImage}
  schemas={schemas}
>

  {/* ── Hero — full-bleed (94vh, slides under the glass header) ─ */}
  <section class="detail-hero" aria-label={project.data.title}>
    <Picture
      src={project.data.heroImage}
      alt={heroAlt}
      formats={["avif", "webp"]}
      widths={[800, 1200, 1920, 2560]}
      sizes="100vw"
      class="detail-hero__image"
      loading="eager"
      fetchpriority="high"
    />
  </section>

  {/* ── Caption below hero — h1 lives here ───────────────────── */}
  <Section surface="light" pad="var(--space-xxl)">
    <div class="detail-caption">
      <div class="detail-caption-place">{project.data.location}</div>
      <h1 class="detail-caption-title">{project.data.title}</h1>
    </div>
  </Section>

  {/* ── Body — centred prose with image bands between paragraphs ─ */}
  {bodyItems.map((item) => (
    item.type === "prose" ? (
      <Section surface="light" pad="var(--space-xl)">
        <div class="detail-prose-wrap" set:html={item.html} />
      </Section>
    ) : (
      <div class="detail-band">
        <Image
          src={item.img}
          widths={[800, 1200, 1920, 2560]}
          sizes="100vw"
          alt={heroAlt}
          class="detail-band-img"
        />
      </div>
    )
  ))}

  {/* ── Remaining gallery images — as before, after the body ──── */}
  {leftover.length === 1 && (
    <div class="detail-band">
      <Image
        src={leftover[0]}
        widths={[800, 1200, 1920, 2560]}
        sizes="100vw"
        alt={heroAlt}
        class="detail-band-img"
      />
    </div>
  )}
  {leftover.length > 1 && (
    <div class="detail-gallery-grid">
      {leftover.map((img, i) => (
        <Image
          src={img}
          widths={[400, 700, 1000]}
          sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
          alt={`${project.data.title}, ${project.data.location}, view ${i + 1}`}
          class="detail-gallery-grid-img"
        />
      ))}
    </div>
  )}

  {/* ── Facts row — centred 4-up (after narrative + gallery) ──── */}
  <Section surface="alt" pad="var(--space-section)">
    <Container>
      <div class="detail-facts-row">
        <div class="detail-facts-cell">
          <div class="detail-facts-label">Location</div>
          <div class="detail-facts-value">{project.data.location}</div>
        </div>
        <div class="detail-facts-cell">
          <div class="detail-facts-label">Project type</div>
          <div class="detail-facts-value">{project.data.sector}</div>
        </div>
        <div class="detail-facts-cell">
          <div class="detail-facts-label">Status</div>
          <div class="detail-facts-value">
            {project.data.status}{project.data.year ? ` ${project.data.year}` : ""}
          </div>
        </div>
        {project.data.features.length > 0 && (
          <div class="detail-facts-cell">
            <div class="detail-facts-label">Sustainability</div>
            <div class="detail-facts-value">{project.data.features.join(" · ")}</div>
          </div>
        )}
      </div>
    </Container>
  </Section>

  {/* ── Testimonial (conditional) ─────────────────────────────── */}
  {project.data.testimonial && (
    <Section surface="light" pad="var(--space-section)">
      <Container>
        <Testimonial
          quote={project.data.testimonial.quote}
          author={project.data.testimonial.author}
        />
      </Container>
    </Section>
  )}

  {/* ── Prev / Next ──────────────────────────────────────────── */}
  <Section surface="alt" pad="var(--space-xxl)">
    <Container>
      <div class="detail-prevnext">

        {prev && (
          <a href={`/projects/${prev}`} class="detail-prevnext-link detail-prevnext-link--prev">
            <div class="detail-prevnext-dir">← Previous</div>
            <div class="detail-prevnext-name">
              {prevTitle ?? "Previous project"}
            </div>
          </a>
        )}

        <Button href="/contact" variant="primary">Enquire about a project</Button>

        {next && (
          <a href={`/projects/${next}`} class="detail-prevnext-link detail-prevnext-link--next">
            <div class="detail-prevnext-dir">Next →</div>
            <div class="detail-prevnext-name">
              {nextTitle ?? "Next project"}
            </div>
          </a>
        )}

      </div>
    </Container>
  </Section>

</PageShell>

<style>
/* ── Full-bleed hero image ───────────────────────────────────── */
.detail-hero {
  margin-top: calc(-1 * var(--header-height));
  height: 94vh;
  overflow: hidden;
  background: var(--color-charcoal);
}
/* <Picture> wraps the <img> in a <picture>; make it fill the hero so the
   img's height:100% resolves against .detail-hero (not the picture box). */
.detail-hero :global(picture) {
  display: block;
  width: 100%;
  height: 100%;
}
.detail-hero__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* ── Caption block below hero ────────────────────────────────── */
.detail-caption {
  text-align: center;
  max-width: 60ch;
  margin: 0 auto;
}
.detail-caption-place {
  font-family: var(--font-text);
  font-size: var(--type-eyebrow-size);
  font-weight: 600;
  letter-spacing: var(--type-eyebrow-tracking);
  text-transform: uppercase;
  color: var(--color-grey-light);
  margin-bottom: var(--space-sm);
}
.detail-caption-title {
  margin: 0;
  font-family: var(--font-display);
  font-size: var(--type-hero-display-size);
  font-weight: 400;
  line-height: 1.05;
  letter-spacing: -0.5px;
  text-transform: uppercase;
  color: var(--color-charcoal);
}

/* ── Facts row — centred 4-up ────────────────────────────────── */
.detail-facts-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-lg);
  text-align: center;
}
@media (max-width: 700px) {
  .detail-facts-row {
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-xl);
  }
}
@media (max-width: 400px) {
  .detail-facts-row { grid-template-columns: 1fr; }
}
.detail-facts-label {
  font-family: var(--font-display);
  font-size: var(--type-eyebrow-size);
  font-weight: 600;
  letter-spacing: var(--type-eyebrow-tracking);
  text-transform: uppercase;
  color: var(--color-purple);
  margin-bottom: 8px;
}
.detail-facts-value {
  font-family: var(--font-text);
  font-size: var(--type-body-size);
  color: var(--color-charcoal);
  line-height: 1.4;
}

/* ── Centred editorial prose ─────────────────────────────────── */
/*
 * All selectors below use :global() because <Content /> renders Markdown
 * beyond Astro's scoped-style boundary. Without :global() the scoped
 * attribute suffix (data-astro-cid-…) never appears on Markdown-rendered
 * elements and the rules have zero specificity match.
 */
.detail-prose-wrap {
  max-width: 60ch;
  margin: 0 auto;
  font-family: var(--font-text);
  font-size: var(--type-lead-airy-size);
  line-height: var(--type-lead-airy-leading);
  color: var(--color-charcoal);
  text-align: center;
}
.detail-prose-wrap :global(h2) {
  font-family: var(--font-display);
  font-size: var(--type-display-md-size);
  font-weight: 600;
  letter-spacing: -0.2px;
  line-height: 1.2;
  color: var(--color-charcoal);
  margin: var(--space-xl) 0 var(--space-md);
}
.detail-prose-wrap :global(h3) {
  font-family: var(--font-display);
  font-size: var(--type-tagline-size);
  font-weight: 600;
  letter-spacing: -0.1px;
  color: var(--color-charcoal);
  margin: var(--space-lg) 0 var(--space-sm);
}
.detail-prose-wrap :global(h4) {
  font-family: var(--font-display);
  font-size: var(--type-tagline-size);
  font-weight: 600;
  line-height: 1.3;
  color: var(--color-charcoal);
  margin: var(--space-md) 0 var(--space-sm);
}
.detail-prose-wrap :global(p) { margin: 0 0 var(--space-md); }
.detail-prose-wrap :global(p:last-child) { margin-bottom: 0; }
.detail-prose-wrap :global(ul),
.detail-prose-wrap :global(ol) {
  margin: 0 0 var(--space-md);
  padding-left: 1.5em;
}
.detail-prose-wrap :global(li) { margin-bottom: 0.4em; }
.detail-prose-wrap :global(a) {
  color: var(--color-indigo-vivid);
  text-decoration: underline;
  text-underline-offset: 2px;
}
.detail-prose-wrap :global(a:hover) { color: var(--color-indigo-deep); }
.detail-prose-wrap :global(strong) {
  font-weight: 600;
  color: var(--color-charcoal);
}
.detail-prose-wrap :global(em) { font-style: italic; }
.detail-prose-wrap :global(blockquote) {
  margin: var(--space-lg) 0;
  border-left: 3px solid var(--color-purple);
  padding-left: var(--space-lg);
}
.detail-prose-wrap :global(blockquote p) {
  font-family: var(--font-display);
  font-size: var(--type-display-md-size);
  font-weight: 500;
  line-height: 1.3;
  letter-spacing: -0.2px;
  color: var(--color-indigo-deep);
  margin: 0;
}
.detail-prose-wrap :global(hr) {
  border: none;
  border-top: 1px solid var(--color-hairline);
  margin: var(--space-xl) 0;
}
.detail-prose-wrap :global(img) {
  max-width: 100%;
  height: auto;
  display: block;
  margin: var(--space-lg) 0;
  border-radius: var(--radius-md);
}

/* ── Full-width gallery image bands ──────────────────────────── */
.detail-band {
  width: 100%;
  line-height: 0;
}
.detail-band-img {
  width: 100%;
  height: auto;
  aspect-ratio: 16 / 9;
  object-fit: cover;
  display: block;
}

/* ── Gallery grid (images 6+) ────────────────────────────────── */
.detail-gallery-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 4px;
}
@media (min-width: 641px) {
  .detail-gallery-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (min-width: 1025px) {
  .detail-gallery-grid { grid-template-columns: repeat(3, 1fr); }
}
.detail-gallery-grid-img {
  width: 100%;
  height: auto;
  aspect-ratio: 4 / 3;
  object-fit: cover;
  display: block;
}

/* ── Prev / next nav ─────────────────────────────────────────── */
.detail-prevnext {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: var(--space-lg);
  flex-wrap: wrap;
}
.detail-prevnext-link {
  text-decoration: none;
  color: inherit;
  flex: 0 1 auto;
}
.detail-prevnext-link--next { text-align: right; }
.detail-prevnext-dir {
  font-family: var(--font-text);
  font-size: var(--type-caption-size);
  color: var(--color-grey-light);
  margin-bottom: 4px;
}
.detail-prevnext-name {
  font-family: var(--font-display);
  font-size: var(--type-tagline-size);
  font-weight: 600;
  color: var(--color-charcoal);
}
.detail-prevnext-link:hover .detail-prevnext-name {
  color: var(--color-indigo-vivid);
}

</style>
