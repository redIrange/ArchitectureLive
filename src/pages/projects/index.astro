---
/**
 * Projects index — ArchitectureLIVE
 * Port of Projects.jsx (ui_kits/website/Projects.jsx).
 * Sections: editorial intro · sector filter · responsive 3-col grid.
 * Filter is pure client-side progressive enhancement (sector-filter.ts).
 * With JS off, all cards remain visible (no display:none in initial HTML).
 */
import PageShell from "../../layouts/PageShell.astro";
import ProjectCard from "../../components/ui/ProjectCard.astro";
import Section from "../../components/ui/Section.astro";
import Container from "../../components/ui/Container.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects", (p) => !p.data.draft))
  .sort((a, b) => (b.data.year ?? 0) - (a.data.year ?? 0));

const sectors = ["All", "Extensions", "New Build", "Education", "Commercial"];
---

<PageShell title="Projects — ArchitectureLIVE" active="projects">

  {/* ── Intro ─────────────────────────────────────────────────── */}
  <Section surface="light" pad="var(--space-xxl)">
    <Container>
      <div class="projects-intro">
        <div class="projects-eyebrow">Projects</div>
        <h1 class="projects-headline">Selected work</h1>
      </div>
      <p class="projects-lead">
        Residential, education and commercial projects across Surrey, West Sussex,
        Hampshire and Berkshire — each shaped by its site, its light and a
        fabric-first approach to energy.
      </p>
    </Container>
  </Section>

  {/* ── Filter + grid ─────────────────────────────────────────── */}
  <Section surface="alt" pad="var(--space-xxl)" style="padding-top:0">
    <Container>

      {/* Segmented filter control */}
      <div class="filter-bar" role="group" aria-label="Filter projects by sector">
        {sectors.map((s) => (
          <button
            class="filter-btn"
            data-filter={s}
            aria-pressed={s === "All" ? "true" : "false"}
          >{s}</button>
        ))}
      </div>

      {/* Project grid — each card wrapper carries data-sector for the filter */}
      <div class="al-grid-3">
        {projects.map((p) => (
          <div data-sector={p.data.sector}>
            <ProjectCard
              href={`/projects/${p.id}`}
              title={p.data.title}
              sector={p.data.sector}
              meta={`${p.data.location} · ${p.data.status}`}
              image={p.data.heroImage}
            />
          </div>
        ))}
      </div>

    </Container>
  </Section>

</PageShell>

<script src="../../scripts/sector-filter.ts"></script>

<style>
/* ── Intro ───────────────────────────────────────────────────────── */
.projects-eyebrow {
  font-family: var(--font-display);
  font-size: var(--type-eyebrow-size);
  font-weight: 600;
  letter-spacing: var(--type-eyebrow-tracking);
  text-transform: uppercase;
  color: var(--color-purple);
  margin-bottom: 14px;
}
.projects-headline {
  margin: 0;
  font-family: var(--font-display);
  font-size: var(--type-hero-display-size);
  font-weight: 400;
  line-height: 1.05;
  letter-spacing: -0.5px;
  text-transform: uppercase;
  color: var(--color-charcoal);
}
.projects-intro {
  max-width: 26ch;
}
.projects-lead {
  max-width: 52ch;
  margin: var(--space-lg) 0 0;
  font-family: var(--font-text);
  font-size: var(--type-lead-airy-size);
  line-height: 1.6;
  color: var(--color-grey-mid);
}

/* ── Filter bar ──────────────────────────────────────────────────── */
.filter-bar {
  display: flex;
  gap: var(--space-xs);
  flex-wrap: wrap;
  padding: var(--space-xl) 0 var(--space-xxl);
  border-bottom: var(--border-hairline);
  margin-bottom: var(--space-xxl);
}

/* Buttons styled to match Tag / segmented-control appearance */
.filter-btn {
  display: inline-flex;
  align-items: center;
  background: none;
  border: none;
  cursor: pointer;
  padding: 6px 10px;
  border-radius: var(--radius-sm);
  font-family: var(--font-display);
  font-size: var(--type-eyebrow-size);
  font-weight: 600;
  letter-spacing: 0.6px;
  text-transform: uppercase;
  color: var(--color-indigo-deep);
  transition: color var(--duration-base) var(--ease-standard),
              background var(--duration-base) var(--ease-standard);
}
.filter-btn:hover {
  color: var(--color-indigo-vivid);
  background: var(--color-lavender);
}
.filter-btn[aria-pressed="true"] {
  color: var(--color-indigo-vivid);
  background: var(--color-lavender);
}

/* ── Project grid ────────────────────────────────────────────────── */
.al-grid-3 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-xl);
}
@media (max-width: 900px) {
  .al-grid-3 { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 600px) {
  .al-grid-3 { grid-template-columns: 1fr; }
}
</style>
