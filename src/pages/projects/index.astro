---
/**
 * Projects index — ArchitectureLIVE
 * Port of Projects.jsx (ui_kits/website/Projects.jsx).
 * Slim header: h1 "Selected work" + sector filters inline on the same row.
 * Dense 1→2→3-col grid of square reveal cards.
 * Filter is pure client-side progressive enhancement (sector-filter.ts).
 * With JS off, all cards remain visible (no display:none in initial HTML).
 */
import PageShell from "../../layouts/PageShell.astro";
import ProjectCard from "../../components/ui/ProjectCard.astro";
import Tag from "../../components/ui/Tag.astro";
import Section from "../../components/ui/Section.astro";
import Container from "../../components/ui/Container.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects", (p) => !p.data.draft))
  .sort((a, b) => (b.data.year ?? 0) - (a.data.year ?? 0));

const sectors = ["All", "Extensions", "New Build", "Education", "Commercial"];
---

<PageShell
  title="Projects · ArchitectureLIVE"
  description="Contemporary house extensions, new builds, education and commercial architecture across Surrey, West Sussex and Hampshire. Selected work from ArchitectureLIVE, RIBA Chartered architects in Haslemere."
  active="projects"
>

  {/* ── Slim header row ─────────────────────────────────────────── */}
  <Section surface="light" pad="var(--space-xl)">
    <Container>
      <div class="projects-header">
        <h1 class="projects-headline">Selected work</h1>
        <div class="projects-filters" role="group" aria-label="Filter projects by sector">
          {sectors.map((s) => (
            <button
              class="filter-btn"
              data-filter={s}
              aria-pressed={s === "All" ? "true" : "false"}
            >
              <Tag variant="filter" label={s} />
            </button>
          ))}
        </div>
      </div>
    </Container>
  </Section>

  {/* ── Dense reveal grid ───────────────────────────────────────── */}
  <Section surface="alt" pad="var(--space-xxl)" style="padding-top:var(--space-lg)">
    <Container>
      <div class="al-grid-projects">
        {projects.map((p) => (
          <div data-sector={p.data.sector}>
            <ProjectCard
              variant="reveal"
              href={`/projects/${p.id}`}
              title={p.data.title}
              sector={p.data.sector}
              meta={`${p.data.location} · ${p.data.status}`}
              image={p.data.heroImage}
              label={p.data.location}
            />
          </div>
        ))}
      </div>
    </Container>
  </Section>

</PageShell>

<script src="../../scripts/sector-filter.ts"></script>

<style>
/* ── Header row ──────────────────────────────────────────────────── */
.projects-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: var(--space-md) var(--space-xl);
  padding-top: var(--space-md);
}
.projects-headline {
  margin: 0;
  font-family: var(--font-display);
  font-size: var(--type-display-md-size);
  font-weight: 400;
  line-height: 1.05;
  letter-spacing: -0.3px;
  text-transform: uppercase;
  color: var(--color-charcoal);
}
.projects-filters {
  display: flex;
  gap: var(--space-lg);
  flex-wrap: wrap;
}

/* Invisible button shell — Tag handles all visual styling */
.filter-btn {
  background: none;
  border: none;
  padding: 0;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
}
/* Active state is driven by aria-pressed (toggled by sector-filter.ts) */
.filter-btn[aria-pressed="true"] :global(.tag--filter) {
  color: var(--color-indigo-vivid);
  font-weight: 700;
}

/* ── Project grid ────────────────────────────────────────────────── */
.al-grid-projects {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-sm);
}
@media (max-width: 900px) {
  .al-grid-projects { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 600px) {
  .al-grid-projects { grid-template-columns: 1fr; }
}
</style>
